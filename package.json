{
  "name": "betterforgeprofits",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --cwd apps/web dev",
    "build": "bun run --cwd apps/web build",
    "start": "bun run --cwd apps/web start",
    "lint": "ultracite check",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "worker:migrate": "bun run --cwd apps/worker migrate",
    "worker:sync-prices": "bun run --cwd apps/worker sync-prices",
    "worker:backfill-aliases": "bun run --cwd apps/worker backfill-aliases",
    "worker:cleanup": "bun run --cwd apps/worker cleanup"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.7",
    "@types/node": "^22",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5",
    "ultracite": "7.3.2"
  }
}
