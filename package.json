{
  "name": "betterforgeprofits",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --cwd apps/web dev",
    "build": "bun run --cwd apps/web build",
    "start": "bun run --cwd apps/web start",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "ultracite check",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "worker:migrate": "bun run --cwd apps/worker migrate",
    "worker:sync-prices": "bun run --cwd apps/worker sync-prices",
    "worker:backfill-aliases": "bun run --cwd apps/worker backfill-aliases"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.7",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.2",
    "drizzle-kit": "^0.31.10",
    "jsdom": "^29.0.1",
    "typescript": "^5",
    "ultracite": "7.3.2",
    "vitest": "^4.1.2"
  }
}
